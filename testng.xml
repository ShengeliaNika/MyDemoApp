<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="My Demo App - Android Suite" verbose="1">

    <listeners>
        <!-- Produces target/allure-results, consumed by the allure-maven plugin / Allure CLI -->
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
        <!-- Attaches a device screenshot to the report on failure -->
        <listener class-name="com.mydemoapp.automation.listeners.AllureScreenshotListener"/>
    </listeners>

    <!-- Runs sequentially: every test reinstalls the app on the single configured
         device/emulator, so concurrent sessions would race for the same device. -->
    <test name="Login and Logout">
        <classes>
            <class name="com.mydemoapp.automation.tests.LoginLogoutTests"/>
        </classes>
    </test>

    <test name="Navigation">
        <classes>
            <class name="com.mydemoapp.automation.tests.NavigationTests"/>
        </classes>
    </test>

    <test name="Cart and Checkout">
        <classes>
            <class name="com.mydemoapp.automation.tests.CartAndCheckoutTests"/>
        </classes>
    </test>

    <test name="Validation Messages">
        <classes>
            <class name="com.mydemoapp.automation.tests.ValidationTests"/>
        </classes>
    </test>

</suite>
